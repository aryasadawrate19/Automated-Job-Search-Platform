# ===== Database =====
DATABASE_URL=postgresql+asyncpg://jobplatform:jobplatform@localhost:5432/jobplatform
DATABASE_URL_SYNC=postgresql://jobplatform:jobplatform@localhost:5432/jobplatform
POSTGRES_USER=jobplatform
POSTGRES_PASSWORD=jobplatform
POSTGRES_DB=jobplatform

# ===== Redis =====
REDIS_URL=redis://localhost:6379/0

# ===== AI Provider Keys (user-provided, stored encrypted) =====
# These are NOT set here — users provide their own keys via the Settings UI.
# The keys are encrypted with AES-256 before storage.
AES_ENCRYPTION_KEY=your-32-byte-hex-encryption-key-here

# ===== Frontend =====
NEXT_PUBLIC_API_URL=http://localhost:8000

# ===== CORS =====
CORS_ORIGINS=http://localhost:3000

# ===== Celery =====
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
